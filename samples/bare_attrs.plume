// Visual modifiers that used to be "bare attrs" now take explicit values
// (SPEC v1: every attr is `name=value`).

scene layout=row gap=20 padding=20 {
  :rect "dashed" size=(80, 40) stroke-style=dashed
  :rect "dotted" size=(80, 40) stroke-style=dotted
  :rect "double" size=(80, 40) double=4
  :rect "shadow" size=(80, 40) shadow=(2, 2, 4)
}

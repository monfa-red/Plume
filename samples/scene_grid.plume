shapes {
  // attr bundle form
  psu :rect radius=5
  bus :slant fill=gray

  // container with layout
  toolbar layout=row gap=10 {
    :icon name=save
    :icon name=copy
  }

  // base + body — full composition.
  panel :group layout=column gap=8 padding=12 {
    :text "Title" at=top weight=bold
    :text "Content"
  }
}

scene {
  :rect "hello"
}

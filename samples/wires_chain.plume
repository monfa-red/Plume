// Wire operators: a chain, plus a couple of line/marker styles.

{
  .loud stroke:red thickness:2
}

cat  |rect| "Cat"
dog  |rect| "Dog"
bird |rect| "Bird"
fish |rect| "Fish"

cat -> dog -> bird -> fish .loud   // chain → 3 wires
cat <-> bird                       // bidirectional
dog --> fish                       // dashed arrow

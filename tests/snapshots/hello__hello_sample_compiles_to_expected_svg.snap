<svg xmlns="http://www.w3.org/2000/svg" viewBox="-54.875 -44.8 109.75 89.6" width="109.75" height="89.6" class="plume">
  <style>@layer plume.defaults { :root, .plume { --plume-accent: #0a84ff;  --plume-bg: white;  --plume-danger: crimson;  --plume-fg: black;  --plume-fill: white;  --plume-font: "sans-serif";  --plume-muted: #888;  --plume-note-bg: #fff9c4;  --plume-on-accent: white;  --plume-shadow: rgba(0, 0, 0, 0.2);  --plume-stroke: #444;  --plume-text-color: var(--plume-fg);  --plume-warn: orange; } }</style>
  <defs/>
  <g class="plume-scene" color="var(--plume-text-color)">
    <g class="plume-node plume-shape-rect" transform="translate(0,0)">
      <rect x="-34.375" y="-24.3" width="68.75" height="48.6" rx="0" ry="0" fill="var(--plume-fill)" stroke="var(--plume-stroke)" stroke-width="1"/>
      <g class="plume-node plume-shape-text" transform="translate(0,0)">
        <text x="0" y="0" text-anchor="middle" dominant-baseline="central" font-size="13" font-family="var(--plume-font)" fill="currentColor">hello</text>
      </g>
    </g>
  </g>
  <g class="plume-wires"/>
</svg>
